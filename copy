    return openai_client, container

openai_client, container = get_clients()

# -----------------------------
# Helpers
# -----------------------------
def embed(text: str):
    return openai_client.embeddings.create(input=text, model=EMBED_MODEL).data[0].embedding

def retrieve_top_k(query_embedding, k: int = 5):
    # Uses Cosmos DB vector search exactly like your script :contentReference[oaicite:3]{index=3}
    query = f"""
        SELECT TOP {k} c.text, VectorDistance(c.embedding, @query_vector) AS similarity_score
        FROM c
        ORDER BY VectorDistance(c.embedding, @query_vector)
    """
    parameters = [{"name": "@query_vector", "value": query_embedding}]
    items = container.query_items(
        query=query,
        parameters=parameters,
        enable_cross_partition_query=True
    )
    return list(items)

def extract_gif_urls(texts: list[str]) -> list[str]:
    """
    Your stored GIF items look like:
    "GIF: {title} | Intent: ... | URL: https://media.giphy.com/media/.../giphy.gif"
    We'll detect those lines and extract URLs.
    """
    urls = []
    pattern = r"(https?://[^\s|]+giphy\.gif)"
    for t in texts:
        if "GIF:" in t and "URL:" in t:
            m = re.search(pattern, t)
            if m:
                urls.append(m.group(1))
    return urls

def build_prompt(user_query: str, context: str) -> str:
    return f"""CONTEXT:
---
{context}
---

USER QUESTION:
---
{user_query}
---
"""

def chat_answer(user_query: str, k: int = 5):
    q_emb = embed(user_query)
    results = retrieve_top_k(q_emb, k=k)

    top_texts = [r.get("text", "") for r in results]
    context = "\n\n".join(top_texts).strip()

    # Extract GIFs if retrieval returns any GIF entries
    gif_urls = extract_gif_urls(top_texts)

    prompt = build_prompt(user_query, context)

    resp = openai_client.chat.completions.create(
        model=CHAT_MODEL,
        messages=[
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user", "content": prompt}
        ],
        temperature=0.5
    )

    answer = resp.choices[0].message.content
    return answer, gif_urls, results

