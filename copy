@st.cache_resource
def get_clients():
    openai_client = AzureOpenAI(
        api_version=AZURE_API_VERSION,
        azure_endpoint=AZURE_ENDPOINT,
        api_key=AZURE_API_KEY,
    )
    cosmos_client = CosmosClient(COSMOS_ENDPOINT, COSMOS_KEY)
